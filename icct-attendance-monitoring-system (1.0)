// ── Page imports ─────────────────────────────────────────────
import RoleSelectionPage from './pages/RoleSelectionPage';
import PinGatePage       from './pages/PinGatePage';
import CheckInPage       from './pages/CheckInPage';
import DashboardPage     from './pages/DashboardPage';
import Header            from './components/Header';

export type AppPage = 'role' | 'pin' | 'checkin' | 'dashboard';

export interface AppContext {
  currentRole: Role | null;
  sessionUser: SessionUser | null;
  navigateTo: (page: AppPage, role?: Role) => void;
  onCheckInSuccess: (user: SessionUser, token: string) => void;
  logout: () => void;
}

export default function App() {
  const [page, setPage]               = useState<AppPage>('role');
  const [currentRole, setCurrentRole] = useState<Role | null>(null);
  const [sessionUser, setSessionUser] = useState<SessionUser | null>(null);

  const navigateTo = useCallback((nextPage: AppPage, role?: Role) => {
    if (role) setCurrentRole(role);
    setPage(nextPage);
  }, []);

  const onCheckInSuccess = useCallback((user: SessionUser, token: string) => {
    saveSession(token, user);
    setSessionUser(user);
    setPage('dashboard');
  }, []);

  const logout = useCallback(() => {
    clearSession();
    clearApiSession();
    setSessionUser(null);
    setCurrentRole(null);
    setPage('role');
  }, []);

  const ctx: AppContext = { currentRole, sessionUser, navigateTo, onCheckInSuccess, logout };

  return (
    <div style={{ minHeight: '100vh', background: '#f4f6fb', fontFamily: "'Segoe UI', sans-serif" }}>
      {/* Header — visible only on dashboard */}
      {page === 'dashboard' && sessionUser && (
        <Header user={sessionUser} onLogout={logout} />
      )}

      {/* Page Router */}
      {page === 'role'      && <RoleSelectionPage ctx={ctx} />}
      {page === 'pin'       && currentRole && <PinGatePage ctx={ctx} />}
      {page === 'checkin'   && currentRole && <CheckInPage ctx={ctx} />}
      {page === 'dashboard' && sessionUser && <DashboardPage ctx={ctx} />}
    </div>
  );
}

