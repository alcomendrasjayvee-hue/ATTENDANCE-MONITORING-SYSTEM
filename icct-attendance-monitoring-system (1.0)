// ─────────────────────────────────────────────────────────────
//  ICCT Attendance System — Prisma Schema
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Roles ──────────────────────────────────────────────────
enum Role {
  student
  staff
  professor
}

// ── Attendance Status ───────────────────────────────────────
enum AttendanceStatus {
  present
  absent
  late
}

// ── User / Member ───────────────────────────────────────────
model User {
  id          String   @id @default(uuid())
  name        String
  idNumber    String   @unique  // student number / staff ID / faculty ID
  role        Role
  section     String?           // student section or department
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attendance  AttendanceRecord[]

  @@map("users")
}

// ── Attendance Record ───────────────────────────────────────
model AttendanceRecord {
  id          String           @id @default(uuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  role        Role
  section     String
  subject     String           // subject for students; work task for staff/professors
  date        String           // stored as YYYY-MM-DD string
  timeIn      String           // stored as HH:MM:SS string
  status      AttendanceStatus @default(present)

  // QR token snapshot (the token used when this check-in was submitted)
  qrToken     String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("attendance_records")
}

// ── QR Token ────────────────────────────────────────────────
// Tracks generated QR tokens and their expiry for validation
model QrToken {
  id        String   @id @default(uuid())
  token     String   @unique
  role      Role
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("qr_tokens")
}

// ── Portal PIN (hashed) ─────────────────────────────────────
// Stores the hashed PINs for staff and professor portals
model PortalPin {
  id        String   @id @default(uuid())
  role      Role     @unique  // one PIN per role (staff / professor)
  pinHash   String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("portal_pins")
}

