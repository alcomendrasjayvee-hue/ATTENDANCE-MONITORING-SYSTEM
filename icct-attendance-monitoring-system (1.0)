import type {
  CheckInPayload, CheckInResponse,
  PinVerifyPayload, PinVerifyResponse,
  QrGenerateResponse, QrValidateResponse,
  AttendanceRecord, AttendanceStats,
  Role, AttendanceStatus,
} from '../../types.d';

const BASE_URL = (globalThis as any).VITE_API_URL || 'http://localhost:3001';
const storage = (globalThis as any).sessionStorage as any;

// Helper function to make API requests with JWT attached
async function apiRequest<T>(
  method: string,
  endpoint: string,
  payload?: unknown
): Promise<T> {
  const headers: Record<string, string> = {
    'Content-Type': 'application/json',
  };
  const token = storage?.getItem('icct_session_token');
  if (token) headers.Authorization = `Bearer ${token}`;

  const options = {
    method,
    headers,
  } as const;
  if (payload) options.body = JSON.stringify(payload);

  const response = await fetch(`${BASE_URL}${endpoint}`, options);
  if (!response.ok) throw new Error(`API error: ${response.statusText}`);
  return response.json();
}

