// ── Attendance Records ───────────────────────────────────────

export interface FetchAttendanceParams {
  role?: Role | 'all';
  date?: string;
  search?: string;
  status?: AttendanceStatus | '';
}

/** Fetch attendance records (visibility controlled server-side by role) */
export async function fetchAttendance(
  params: FetchAttendanceParams = {}
): Promise<{ records: AttendanceRecord[]; total: number }> {
  const query: Record<string, string> = {};
  if (params.role && params.role !== 'all') query.role = params.role;
  if (params.date)   query.date   = params.date;
  if (params.search) query.search = params.search;
  if (params.status) query.status = params.status;
  const { data } = await api.get('/api/attendance', { params: query });
  return data;
}

/** Fetch aggregated stats for the current user's scope */
export async function fetchStats(): Promise<AttendanceStats> {
  const { data } = await api.get<AttendanceStats>('/api/attendance/stats');
  return data;
}

/** Mark a record's status (professors only) */
export async function markAttendance(
  recordId: string,
  status: AttendanceStatus
): Promise<AttendanceRecord> {
  const { data } = await api.patch(`/api/attendance/${recordId}/status`, { status });
  return data.record;
}

/** Update a portal PIN (professors only) */
export async function updatePin(role: 'staff' | 'professor', newPin: string): Promise<void> {
  await api.put('/api/admin/pin', { role, newPin });
}

/** Clear session (logout) */
export function clearSession(): void {
  sessionStorage.removeItem('icct_session_token');
}

