import { useState, useEffect, useCallback } from 'react';
import type { AttendanceRecord, AttendanceStats, AttendanceStatus, Role } from '../../../types.d';
import { fetchAttendance, fetchStats, markAttendance as markApi } from '../upload';

export interface UseAttendanceOptions {
  tab: 'all' | Role;
  search: string;
  status: AttendanceStatus | '';
}

export function useAttendance({ tab, search, status }: UseAttendanceOptions) {
  const [records, setRecords] = useState<AttendanceRecord[]>([]);
  const [stats,   setStats]   = useState<AttendanceStats | null>(null);
  const [loading, setLoading] = useState(false);
  const [error,   setError]   = useState<string | null>(null);

  const load = useCallback(async () => {
    setLoading(true);
    setError(null);
    try {
      const [recRes, statsRes] = await Promise.all([
        fetchAttendance({ role: tab, search, status }),
        fetchStats(),
      ]);
      setRecords(recRes.records);
      setStats(statsRes);
    } catch (err: any) {
      setError(err?.response?.data?.error || 'Failed to load data');
    } finally {
      setLoading(false);
    }
  }, [tab, search, status]);

  useEffect(() => { load(); }, [load]);

  const markRecord = useCallback(async (id: string, newStatus: AttendanceStatus) => {
    try {
      const updated = await markApi(id, newStatus);
      setRecords(prev => prev.map(r => r.id === id ? { ...r, status: updated.status } : r));
    } catch (err: any) {
      setError(err?.response?.data?.error || 'Failed to update status');
    }
  }, []);

  return { records, stats, loading, error, reload: load, markRecord };
}

