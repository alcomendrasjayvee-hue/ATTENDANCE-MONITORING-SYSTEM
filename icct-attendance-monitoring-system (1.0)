-- Extensions
CREATE EXTENSION IF NOT EXISTS "uuid-ossp";

-- ── Enums ──────────────────────────────────────────────────
CREATE TYPE role_enum AS ENUM ('student', 'staff', 'professor');
CREATE TYPE attendance_status AS ENUM ('present', 'absent', 'late');

-- ── Users ──────────────────────────────────────────────────
CREATE TABLE IF NOT EXISTS users (
  id          UUID          PRIMARY KEY DEFAULT uuid_generate_v4(),
  name        VARCHAR(255)  NOT NULL,
  id_number   VARCHAR(100)  UNIQUE NOT NULL,  -- student no / staff ID / faculty ID
  role        role_enum     NOT NULL,
  section     VARCHAR(100),                   -- section or department
  created_at  TIMESTAMP     NOT NULL DEFAULT NOW(),
  updated_at  TIMESTAMP     NOT NULL DEFAULT NOW()
);

-- ── Attendance Records ──────────────────────────────────────
CREATE TABLE IF NOT EXISTS attendance_records (
  id          UUID              PRIMARY KEY DEFAULT uuid_generate_v4(),
  user_id     UUID              NOT NULL REFERENCES users(id) ON DELETE CASCADE,
  role        role_enum         NOT NULL,
  section     VARCHAR(100)      NOT NULL,
  subject     VARCHAR(255)      NOT NULL,  -- subject or work task
  date        VARCHAR(10)       NOT NULL,  -- YYYY-MM-DD
  time_in     VARCHAR(8)        NOT NULL,  -- HH:MM:SS
  status      attendance_status NOT NULL DEFAULT 'present',
  qr_token    VARCHAR(255),
  created_at  TIMESTAMP         NOT NULL DEFAULT NOW(),
  updated_at  TIMESTAMP         NOT NULL DEFAULT NOW()
);

-- ── QR Tokens ───────────────────────────────────────────────
CREATE TABLE IF NOT EXISTS qr_tokens (
  id          UUID        PRIMARY KEY DEFAULT uuid_generate_v4(),
  token       VARCHAR(255) UNIQUE NOT NULL,
  role        role_enum   NOT NULL,
  expires_at  TIMESTAMP   NOT NULL,
  used        BOOLEAN     NOT NULL DEFAULT FALSE,
  created_at  TIMESTAMP   NOT NULL DEFAULT NOW()
);

-- ── Portal PINs (hashed) ────────────────────────────────────
CREATE TABLE IF NOT EXISTS portal_pins (
  id          UUID        PRIMARY KEY DEFAULT uuid_generate_v4(),
  role        role_enum   UNIQUE NOT NULL,
  pin_hash    VARCHAR(255) NOT NULL,
  updated_at  TIMESTAMP   NOT NULL DEFAULT NOW(),
  created_at  TIMESTAMP   NOT NULL DEFAULT NOW()
);

-- ── Indexes ─────────────────────────────────────────────────
CREATE INDEX IF NOT EXISTS idx_attendance_user    ON attendance_records(user_id);
CREATE INDEX IF NOT EXISTS idx_attendance_date    ON attendance_records(date);
CREATE INDEX IF NOT EXISTS idx_attendance_role    ON attendance_records(role);
CREATE INDEX IF NOT EXISTS idx_qr_token_token     ON qr_tokens(token);
CREATE INDEX IF NOT EXISTS idx_qr_token_expires   ON qr_tokens(expires_at);

-- ── Auto-update updated_at ──────────────────────────────────
CREATE OR REPLACE FUNCTION update_updated_at()
RETURNS TRIGGER AS $$
BEGIN
  NEW.updated_at = NOW();
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_users_updated_at
  BEFORE UPDATE ON users
  FOR EACH ROW EXECUTE FUNCTION update_updated_at();

CREATE TRIGGER trg_attendance_updated_at
  BEFORE UPDATE ON attendance_records
  FOR EACH ROW EXECUTE FUNCTION update_updated_at();

CREATE TRIGGER trg_portal_pins_updated_at
  BEFORE UPDATE ON portal_pins
  FOR EACH ROW EXECUTE FUNCTION update_updated_at();

// ─────────────────────────────────────────────────────────────
//  ICCT Attendance System — Database Seeder (script.js)
//  Run: node script.js
//  Seeds the initial PIN hashes for staff and professor portals
// ─────────────────────────────────────────────────────────────

const { PrismaClient } = require('@prisma/client');
const bcrypt = require('bcryptjs');
require('dotenv').config();

const prisma = new PrismaClient();

const STAFF_PIN     = process.env.STAFF_PIN     || '1234';
const PROFESSOR_PIN = process.env.PROFESSOR_PIN || '5678';
const SALT_ROUNDS   = 12;

async function seed() {
  console.log('\n🌱 Seeding ICCT Attendance database...\n');

  // ── Seed Portal PINs ──────────────────────────────────────
  const staffHash = await bcrypt.hash(STAFF_PIN, SALT_ROUNDS);
  const profHash  = await bcrypt.hash(PROFESSOR_PIN, SALT_ROUNDS);

  const staffPin = await prisma.portalPin.upsert({
    where:  { role: 'staff' },
    update: { pinHash: staffHash },
    create: { role: 'staff', pinHash: staffHash },
  });
  console.log(`✅ Staff PIN seeded     (role: ${staffPin.role})`);

  const profPin = await prisma.portalPin.upsert({
    where:  { role: 'professor' },
    update: { pinHash: profHash },
    create: { role: 'professor', pinHash: profHash },
  });
  console.log(`✅ Professor PIN seeded (role: ${profPin.role})`);

  // ── Seed Sample Users (optional, for dev testing) ─────────
  if (process.env.NODE_ENV === 'development') {
    console.log('\n📋 Seeding sample users for development...');

    const sampleUsers = [
      { name: 'Juan dela Cruz',  idNumber: '2024-00001', role: 'student',   section: 'BSIT-3A' },
      { name: 'Maria Santos',    idNumber: 'STAFF-001',  role: 'staff',     section: 'Admin Office' },
      { name: 'Dr. Ana Reyes',   idNumber: 'FAC-001',    role: 'professor', section: 'CS Dept.' },
    ];

    for (const u of sampleUsers) {
      const user = await prisma.user.upsert({
        where:  { idNumber: u.idNumber },
        update: {},
        create: { name: u.name, idNumber: u.idNumber, role: u.role, section: u.section },
      });
      console.log(`  👤 ${user.role.padEnd(9)} → ${user.name} (${user.idNumber})`);
    }
  }

  console.log('\n🎓 Seeding complete!\n');
  console.log('─────────────────────────────────────────────');
  console.log('  Default PINs (change in production!):');
  console.log(`  Staff PIN:     ${STAFF_PIN}`);
  console.log(`  Professor PIN: ${PROFESSOR_PIN}`);
  console.log('─────────────────────────────────────────────\n');
}

seed()
  .catch((err) => { console.error('❌ Seed failed:', err); process.exit(1); })
  .finally(() => prisma.$disconnect());
