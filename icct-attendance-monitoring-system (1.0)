import express, { Request, Response, NextFunction } from 'express';
import cors from 'cors';
import dotenv from 'dotenv';
import { PrismaClient } from '@prisma/client';
import bcrypt from 'bcryptjs';
import jwt from 'jsonwebtoken';
import { v4 as uuidv4 } from 'uuid';

dotenv.config();

const app = express();
const prisma = new PrismaClient();
const PORT = process.env.PORT || 3001;
const JWT_SECRET = process.env.JWT_SECRET || 'fallback_secret';
const QR_EXPIRY = parseInt(process.env.QR_EXPIRY_SECONDS || '1800', 10);

// ── Middleware ────────────────────────────────────────────────
app.use(cors({ origin: process.env.CORS_ORIGIN || 'http://localhost:5173', credentials: true }));
app.use(express.json());

// ── Auth Middleware ───────────────────────────────────────────
interface AuthRequest extends Request {
  user?: { id: string; role: string; name: string };
}

function authMiddleware(req: AuthRequest, res: Response, next: NextFunction) {
  const authHeader = req.headers.authorization;
  if (!authHeader?.startsWith('Bearer ')) {
    return res.status(401).json({ error: 'Unauthorized' });
  }
  try {
    const token = authHeader.split(' ')[1];
    const decoded = jwt.verify(token, JWT_SECRET) as { id: string; role: string; name: string };
    req.user = decoded;
    next();
  } catch {
    return res.status(401).json({ error: 'Invalid or expired token' });
  }
}

// Role guard factory
function requireRole(...roles: string[]) {
  return (req: AuthRequest, res: Response, next: NextFunction) => {
    if (!req.user || !roles.includes(req.user.role)) {
      return res.status(403).json({ error: 'Forbidden — insufficient permissions' });
    }
    next();
  };
}

// ═══════════════════════════════════════════════════════════
//  ROUTES
// ═══════════════════════════════════════════════════════════

// ── Health check ──────────────────────────────────────────
app.get('/api/health', (_req, res) => {
  res.json({ status: 'ok', timestamp: new Date().toISOString(), system: 'ICCT-CSD Attendance' });
});

// ── PIN Verification ──────────────────────────────────────
// POST /api/auth/verify-pin
// Body: { role: 'staff' | 'professor', pin: '1234' }
app.post('/api/auth/verify-pin', async (req, res) => {
  const { role, pin } = req.body as { role: string; pin: string };
  if (!role || !pin) return res.status(400).json({ error: 'role and pin are required' });
  if (!['staff', 'professor'].includes(role)) {
    return res.status(400).json({ error: 'PIN verification only applies to staff and professors' });
  }
  try {
    const record = await prisma.portalPin.findUnique({ where: { role: role as any } });
    if (!record) return res.status(404).json({ error: 'PIN not configured for this role' });
    const valid = await bcrypt.compare(pin, record.pinHash);
    if (!valid) return res.status(401).json({ error: 'Incorrect PIN' });
    // Issue a short-lived JWT for portal access
    const accessToken = jwt.sign({ role, pinVerified: true }, JWT_SECRET, { expiresIn: '2h' });
    return res.json({ success: true, accessToken });
  } catch (err) {
    console.error(err);
    return res.status(500).json({ error: 'Server error' });
  }
});

// ── QR Token Generation ───────────────────────────────────
// POST /api/qr/generate
// Body: { role: 'student' | 'staff' | 'professor' }
app.post('/api/qr/generate', async (req, res) => {
  const { role } = req.body as { role: string };
  if (!['student', 'staff', 'professor'].includes(role)) {
    return res.status(400).json({ error: 'Invalid role' });
  }
  try {
    const token = uuidv4().replace(/-/g, '').toUpperCase();
    const expiresAt = new Date(Date.now() + QR_EXPIRY * 1000);
    await prisma.qrToken.create({ data: { token, role: role as any, expiresAt } });
    return res.json({ token, expiresAt, expirySeconds: QR_EXPIRY });
  } catch (err) {
    console.error(err);
    return res.status(500).json({ error: 'Failed to generate QR token' });
  }
});

// ── QR Token Validation ───────────────────────────────────
// GET /api/qr/validate/:token
app.get('/api/qr/validate/:token', async (req, res) => {
  const { token } = req.params;
  try {
    const record = await prisma.qrToken.findUnique({ where: { token } });
    if (!record) return res.status(404).json({ valid: false, reason: 'Token not found' });
    if (record.used)  return res.status(410).json({ valid: false, reason: 'Token already used' });
    if (new Date() > record.expiresAt) return res.status(410).json({ valid: false, reason: 'Token expired' });
    return res.json({ valid: true, role: record.role, expiresAt: record.expiresAt });
  } catch (err) {
    console.error(err);
    return res.status(500).json({ error: 'Server error' });
  }
});

// ── Check-In ──────────────────────────────────────────────
// POST /api/checkin
// Body: { name, idNumber, role, section, subject, date, qrToken? }
app.post('/api/checkin', async (req, res) => {
  const { name, idNumber, role, section, subject, date, qrToken } = req.body as {
    name: string; idNumber: string; role: string;
    section: string; subject: string; date: string; qrToken?: string;
  };

  if (!name || !idNumber || !role || !section || !subject || !date) {
    return res.status(400).json({ error: 'All fields are required' });
  }
  if (!['student', 'staff', 'professor'].includes(role)) {
    return res.status(400).json({ error: 'Invalid role' });
  }

  try {
    // Validate QR token if provided
    if (qrToken) {
      const qr = await prisma.qrToken.findUnique({ where: { token: qrToken } });
      if (!qr || qr.used || new Date() > qr.expiresAt) {
        return res.status(410).json({ error: 'QR token is invalid or expired' });
      }
      // Mark token as used
      await prisma.qrToken.update({ where: { token: qrToken }, data: { used: true } });
    }

    // Upsert user (find or create by idNumber)
    const user = await prisma.user.upsert({
      where: { idNumber },
      update: { name, section },
      create: { name, idNumber, role: role as any, section },
    });

    // Create attendance record
    const now = new Date();
    const timeIn = now.toLocaleTimeString('en-PH', {
      hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: true,
    });

    const record = await prisma.attendanceRecord.create({
      data: {
        userId: user.id, role: role as any, section, subject, date, timeIn,
        status: 'present', qrToken: qrToken || null,
      },
      include: { user: true },
    });

    // Issue session JWT
    const sessionToken = jwt.sign(
      { id: user.id, role: user.role, name: user.name },
      JWT_SECRET,
      { expiresIn: process.env.JWT_EXPIRES_IN || '8h' }
    );

    return res.status(201).json({ success: true, record, sessionToken });
  } catch (err) {
    console.error(err);
    return res.status(500).json({ error: 'Check-in failed' });
  }
});

// ── Get Attendance Records ────────────────────────────────
// GET /api/attendance
// Query: ?role=student|staff|professor&date=YYYY-MM-DD&search=name
// Access: professors → all; staff → staff only; student → own only
app.get('/api/attendance', authMiddleware, async (req: AuthRequest, res) => {
  const { role: filterRole, date, search, status } = req.query as Record<string, string>;
  const viewer = req.user!;

  try {
    // Build visibility filter based on viewer's role
    let roleFilter: any = {};
    if (viewer.role === 'student') {
      // Students: only own records
      roleFilter = { user: { idNumber: viewer.id } };
    } else if (viewer.role === 'staff') {
      // Staff: only staff records — NOT student or professor
      roleFilter = { role: 'staff' };
    }
    // Professors: no restriction (see all)

    const where: any = {
      ...roleFilter,
      ...(filterRole && viewer.role === 'professor' ? { role: filterRole } : {}),
      ...(date ? { date } : {}),
      ...(status ? { status } : {}),
      ...(search ? {
        OR: [
          { user: { name: { contains: search, mode: 'insensitive' } } },
          { user: { idNumber: { contains: search, mode: 'insensitive' } } },
          { section: { contains: search, mode: 'insensitive' } },
        ],
      } : {}),
    };

    const records = await prisma.attendanceRecord.findMany({
      where,
      include: { user: { select: { name: true, idNumber: true } } },
      orderBy: { createdAt: 'desc' },
    });

    return res.json({ records, total: records.length });
  } catch (err) {
    console.error(err);
    return res.status(500).json({ error: 'Failed to fetch records' });
  }
});

// ── Update Attendance Status ──────────────────────────────
// PATCH /api/attendance/:id/status
// Body: { status: 'present' | 'absent' | 'late' }
// Access: professors only
app.patch(
  '/api/attendance/:id/status',
  authMiddleware,
  requireRole('professor'),
  async (req: AuthRequest, res) => {
    const { id } = req.params;
    const { status } = req.body as { status: string };
    if (!['present', 'absent', 'late'].includes(status)) {
      return res.status(400).json({ error: 'Invalid status' });
    }
    try {
      const updated = await prisma.attendanceRecord.update({
        where: { id },
        data: { status: status as any },
        include: { user: { select: { name: true, idNumber: true } } },
      });
      return res.json({ success: true, record: updated });
    } catch (err) {
      console.error(err);
      return res.status(500).json({ error: 'Failed to update status' });
    }
  }
);

// ── Attendance Stats ──────────────────────────────────────
// GET /api/attendance/stats
// Access: professors → all roles; staff → staff only; student → own only
app.get('/api/attendance/stats', authMiddleware, async (req: AuthRequest, res) => {
  const viewer = req.user!;
  const today = new Date().toISOString().split('T')[0];
  const weekAgo = new Date(Date.now() - 7 * 864e5).toISOString().split('T')[0];

  try {
    let baseWhere: any = {};
    if (viewer.role === 'student') baseWhere = { user: { idNumber: viewer.id } };
    else if (viewer.role === 'staff') baseWhere = { role: 'staff' };

    const [total, todayCount, weekCount, presentCount] = await Promise.all([
      prisma.attendanceRecord.count({ where: baseWhere }),
      prisma.attendanceRecord.count({ where: { ...baseWhere, date: today } }),
      prisma.attendanceRecord.count({ where: { ...baseWhere, date: { gte: weekAgo } } }),
      prisma.attendanceRecord.count({ where: { ...baseWhere, status: 'present' } }),
    ]);

    const presentRate = total > 0 ? Math.round((presentCount / total) * 100) : null;
    return res.json({ total, today: todayCount, week: weekCount, presentRate });
  } catch (err) {
    console.error(err);
    return res.status(500).json({ error: 'Failed to fetch stats' });
  }
});

// ── Update Portal PIN (professor only) ───────────────────
// PUT /api/admin/pin
// Body: { role: 'staff' | 'professor', newPin: '0000' }
app.put(
  '/api/admin/pin',
  authMiddleware,
  requireRole('professor'),
  async (req: AuthRequest, res) => {
    const { role, newPin } = req.body as { role: string; newPin: string };
    if (!['staff', 'professor'].includes(role)) {
      return res.status(400).json({ error: 'Invalid role for PIN update' });
    }
    if (!newPin || newPin.length < 4) {
      return res.status(400).json({ error: 'PIN must be at least 4 digits' });
    }
    try {
      const pinHash = await bcrypt.hash(newPin, 12);
      await prisma.portalPin.upsert({
        where: { role: role as any },
        update: { pinHash },
        create: { role: role as any, pinHash },
      });
      return res.json({ success: true, message: `PIN updated for ${role}` });
    } catch (err) {
      console.error(err);
      return res.status(500).json({ error: 'Failed to update PIN' });
    }
  }
);

// ── Start Server ──────────────────────────────────────────
app.listen(PORT, () => {
  console.log(`\n🎓 ICCT Attendance Backend running on http://localhost:${PORT}`);
  console.log(`📋 Computer Studies Department`);
  console.log(`🔗 Health: http://localhost:${PORT}/api/health\n`);
});

export default app;

