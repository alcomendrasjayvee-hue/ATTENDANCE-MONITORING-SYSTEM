import type { Role, SessionUser } from '../../types.d';

const SESSION_KEY = 'icct_session_token';
const USER_KEY    = 'icct_session_user';

/** Decode JWT payload without verifying (client-side display only) */
function decodeJwt(token: string): Record<string, unknown> | null {
  try {
    const payload = token.split('.')[1];
    return JSON.parse(atob(payload));
  } catch {
    return null;
  }
}

/** Save session token and user info after check-in */
export function saveSession(token: string, user: SessionUser): void {
  sessionStorage.setItem(SESSION_KEY, token);
  sessionStorage.setItem(USER_KEY, JSON.stringify(user));
}

/** Load saved session user */
export function loadSessionUser(): SessionUser | null {
  try {
    const raw = sessionStorage.getItem(USER_KEY);
    return raw ? (JSON.parse(raw) as SessionUser) : null;
  } catch {
    return null;
  }
}

/** Check if the session token is still valid (not expired) */
export function isSessionValid(): boolean {
  const token = sessionStorage.getItem(SESSION_KEY);
  if (!token) return false;
  const payload = decodeJwt(token);
  if (!payload || typeof payload.exp !== 'number') return false;
  return payload.exp * 1000 > Date.now();
}

/** Clear all session data */
export function clearSession(): void {
  sessionStorage.removeItem(SESSION_KEY);
  sessionStorage.removeItem(USER_KEY);
}

/** Get session token */
export function getSessionToken(): string | null {
  return sessionStorage.getItem(SESSION_KEY);
}

// ── Access control helpers ───────────────────────────────────

/** Returns which tab keys a role is allowed to see */
export function getAllowedTabs(role: Role): Array<'all' | Role> {
  if (role === 'professor') return ['all', 'student', 'staff', 'professor'];
  if (role === 'staff')     return ['staff'];
  return ['student'];
}

/** Returns whether a role can mark attendance */
export function canMark(role: Role): boolean {
  return role === 'professor';
}

/** Returns whether a role requires a PIN to enter its portal */
export function requiresPin(role: Role): boolean {
  return role === 'staff' || role === 'professor';
}

/** Returns the scope description shown in the dashboard chip */
export function getScopeDescription(role: Role): string {
  if (role === 'professor') {
    return '👁 Full Access — you can view all student, staff, and professor records';
  }
  if (role === 'staff') {
    return '🗂 Staff View — you can only view your own staff attendance records';
  }
  return '🎓 Student View — you can only view your own attendance records';
}

